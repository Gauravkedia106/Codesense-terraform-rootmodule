{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3ReadUsageFiles",
      "Effect": "Allow",
      "Action": "s3:GetObject",
      "Resource": [
        "arn:aws:s3:::codesenseai-emami-dev-*",
        "arn:aws:s3:::codesenseai-emami-dev-*/*",
        "arn:aws:s3:::codesenseai-emami-prd-*",
        "arn:aws:s3:::codesenseai-emami-prd-*/*"
      ]
    },
    {
      "Sid": "DynamoDBManifestTableAccess",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:UpdateItem"
      ],
      "Resource": [
        "arn:aws:dynamodb:us-east-1:*:table/codesenseai-emami-dev-*",
        "arn:aws:dynamodb:us-east-1:*:table/codesenseai-emami-prd-*"
      ]
    },
    {
      "Sid": "CloudWatchLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": [
        "arn:aws:logs:us-east-1:*:log-group:/aws/lambda/codesenseai-emami-dev-*:*",
        "arn:aws:logs:us-east-1:*:log-group:/aws/lambda/codesenseai-emami-prd-*:*"
      ]
    },
    {
      "Sid": "SQSPermissions",
      "Effect": "Allow",
      "Action": [
        "sqs:ReceiveMessage",
        "sqs:DeleteMessage",
        "sqs:GetQueueAttributes",
        "sqs:SendMessage"
      ],
      "Resource": [
        "arn:aws:sqs:us-east-1:*:codesenseai-emami-dev-*",
        "arn:aws:sqs:us-east-1:*:codesenseai-emami-prd-*"
      ]
    },
    {
      "Sid": "bedrock",
      "Effect": "Allow",
      "Action": "bedrock:InvokeModel",
      "Resource": "arn:aws:bedrock:us-east-1::foundation-model/anthropic.claude-3-5-sonnet-20240620-v1:0"
    }
  ]
}