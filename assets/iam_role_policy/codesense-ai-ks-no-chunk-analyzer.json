{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "BedrockAccess",
      "Effect": "Allow",
      "Action": "bedrock:InvokeModel",
      "Resource": [
        "arn:aws:bedrock:us-east-1::foundation-model/anthropic.claude-3-5-sonnet-20240620-v1:0",
        "arn:aws:bedrock:us-east-1::foundation-model/global.anthropic.claude-sonnet-4-5-20250929-v1:0"
      ]
    },
    {
      "Sid": "S3ReadAccess",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:HeadObject"
      ],
      "Resource": [
        "arn:aws:s3:::codesenseai-emami-dev-*",
        "arn:aws:s3:::codesenseai-emami-dev-*/*",
        "arn:aws:s3:::codesenseai-emami-prd-*",
        "arn:aws:s3:::codesenseai-emami-prd-*/*"
      ]
    },
    {
      "Sid": "DynamoDBAccess",
      "Effect": "Allow",
      "Action": [
        "dynamodb:PutItem",
        "dynamodb:UpdateItem"
      ],
      "Resource": [
        "arn:aws:dynamodb:us-east-1:*:table/codesenseai-emami-dev-*",
        "arn:aws:dynamodb:us-east-1:*:table/codesenseai-emami-prd-*"
      ]
    },
    {
      "Sid": "SQSTriggerPermissions",
      "Effect": "Allow",
      "Action": [
        "sqs:ReceiveMessage",
        "sqs:DeleteMessage",
        "sqs:GetQueueAttributes"
      ],
      "Resource": [
        "arn:aws:sqs:us-east-1:*:codesenseai-emami-dev-*",
        "arn:aws:sqs:us-east-1:*:codesenseai-emami-prd-*"
      ]
    },
    {
      "Sid": "CloudWatchLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": [
        "arn:aws:logs:us-east-1:*:log-group:/aws/lambda/codesenseai-emami-dev-*:*",
        "arn:aws:logs:us-east-1:*:log-group:/aws/lambda/codesenseai-emami-prd-*:*"
      ]
    }
  ]
}