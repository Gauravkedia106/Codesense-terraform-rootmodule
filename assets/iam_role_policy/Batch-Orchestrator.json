{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DynamoDBPermissions",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:UpdateItem"
      ],
      "Resource": [
        "arn:aws:dynamodb:us-east-1:*:table/codesenseai-emami-dev-*",
        "arn:aws:dynamodb:us-east-1:*:table/codesenseai-emami-prd-*"
      ]
    },
    {
      "Sid": "S3Permissions",
      "Effect": "Allow",
      "Action": "s3:GetObject",
      "Resource": [
        "arn:aws:s3:::codesenseai-emami-dev-*",
        "arn:aws:s3:::codesenseai-emami-dev-*/*",
        "arn:aws:s3:::codesenseai-emami-prd-*",
        "arn:aws:s3:::codesenseai-emami-prd-*/*"
      ]
    },
    {
      "Sid": "LambdaBasicExecution",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": [
        "arn:aws:logs:us-east-1:*:log-group:/aws/lambda/codesenseai-emami-dev-*:*",
        "arn:aws:logs:us-east-1:*:log-group:/aws/lambda/codesenseai-emami-prd-*:*"
      ]
    },
    {
      "Sid": "BedrockInvokeModel",
      "Effect": "Allow",
      "Action": [
        "bedrock:InvokeModel",
        "bedrock:CountTokens"
      ],
      "Resource": "arn:aws:bedrock:us-east-1:*:foundation-model/anthropic.claude-3-5-sonnet-20240620-v1:0"
    },
    {
      "Sid": "SQSPermissions",
      "Effect": "Allow",
      "Action": [
        "sqs:DeleteMessage",
        "sqs:ReceiveMessage",
        "sqs:SendMessage",
        "sqs:GetQueueAttributes"
      ],
      "Resource": [
        "arn:aws:sqs:us-east-1:*:codesenseai-emami-dev-*",
        "arn:aws:sqs:us-east-1:*:codesenseai-emami-prd-*"
      ]
    },
    {
      "Sid": "InvokeLambda",
      "Effect": "Allow",
      "Action": "lambda:InvokeFunction",
      "Resource": [
        "arn:aws:lambda:us-east-1:*:function:codesenseai-emami-dev-*",
        "arn:aws:lambda:us-east-1:*:function:codesenseai-emami-prd-*"
      ]
    }
  ]
}